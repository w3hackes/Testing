#
# Example environment variables for local development.
# Copy to `.env` (do not commit real secrets).
#

# Option 1: direct Postgres connection (unused if you use HTTP API)
#DATABASE_URL=postgresql+psycopg://postgres:<password>@<host>:5432/postgres?sslmode=require

# Option 2: Supabase HTTP API (service_role key, server-side only)
SUPABASE_URL=SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY

# Ledger tables (match your Supabase table names)
BLOOD_LEDGER_TABLE=blood_events
PLASMA_LEDGER_TABLE=plasma_events
